{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements-crypto.txt"
  },
  "deploy": {
    "startCommand": "uvicorn dashboard_server:app --host 0.0.0.0 --port ${PORT:-8080}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
