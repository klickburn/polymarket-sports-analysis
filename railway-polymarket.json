{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install requests cryptography fastapi uvicorn"
  },
  "deploy": {
    "startCommand": "uvicorn polymarket_server:app --host 0.0.0.0 --port ${PORT:-8081}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
